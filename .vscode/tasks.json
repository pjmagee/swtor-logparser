{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "detail": "Build the whole solution (Debug).",
      "command": "dotnet",
      "type": "process",
      "args": ["build", "SwtorLogParser.slnx", "/property:GenerateFullPaths=true", "/consoleloggerparameters:NoSummary"],
      "problemMatcher": "$msCompile",
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "build-overlay",
      "detail": "Build the ImGui overlay (win-x64 RID — needed for CsWin32 + native GLFW assets).",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/SwtorLogParser.Overlay.ImGui/SwtorLogParser.Overlay.ImGui.csproj",
        "-r", "win-x64",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "build-cli",
      "detail": "Build the managed CLI.",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/SwtorLogParser.Cli/SwtorLogParser.Cli.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "test",
      "detail": "Run the test suite with coverage.",
      "command": "dotnet",
      "type": "process",
      "args": [
        "test",
        "${workspaceFolder}/SwtorLogParser.Tests/SwtorLogParser.Tests.csproj",
        "--collect:XPlat Code Coverage"
      ],
      "problemMatcher": "$msCompile",
      "group": { "kind": "test", "isDefault": true }
    },
    {
      "label": "publish-overlay",
      "detail": "Publish the overlay as a self-contained win-x64 executable.",
      "command": "dotnet",
      "type": "process",
      "args": [
        "publish",
        "${workspaceFolder}/SwtorLogParser.Overlay.ImGui/SwtorLogParser.Overlay.ImGui.csproj",
        "-c", "Release",
        "-r", "win-x64",
        "--self-contained"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    }
  ]
}
