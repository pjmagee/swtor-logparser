<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SwtorLogParser.Overlay.WinUi.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SwtorLogParser.Overlay.WinUi.ViewModels"
    Title="SWTOR Log Parser">

    <!-- Phase 9: live DPS/HPS render surface. NORMAL, OPAQUE, movable window (standard title bar).
         Transparency / borderless / click-through / drag / topmost are Phase 10 — NOT here yet.
         Rows are bound via compiled x:Bind to MainViewModel.Rows; the VM marshals every update onto
         the UI thread (see MainViewModel), so this XAML is only ever touched on the UI thread. -->
    <Grid Padding="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header row: 5 parity columns Player / DPS / Crit% / HPS / Crit% -->
        <Grid Grid.Row="0" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Player"  FontWeight="SemiBold" />
            <TextBlock Grid.Column="1" Text="DPS"     FontWeight="SemiBold" TextAlignment="Right" />
            <TextBlock Grid.Column="2" Text="Crit %"  FontWeight="SemiBold" TextAlignment="Right" />
            <TextBlock Grid.Column="3" Text="HPS"     FontWeight="SemiBold" TextAlignment="Right" />
            <TextBlock Grid.Column="4" Text="Crit %"  FontWeight="SemiBold" TextAlignment="Right" />
        </Grid>

        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.Rows}"
                  SelectionMode="None"
                  IsItemClickEnabled="False">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="4,2" />
                    <Setter Property="MinHeight" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:EntryViewModel">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Bind Name,  Mode=OneWay}" />
                        <TextBlock Grid.Column="1" Text="{x:Bind DPS,   Mode=OneWay}" TextAlignment="Right" />
                        <TextBlock Grid.Column="2" Text="{x:Bind DCrit, Mode=OneWay}" TextAlignment="Right" />
                        <TextBlock Grid.Column="3" Text="{x:Bind HPS,   Mode=OneWay}" TextAlignment="Right" />
                        <TextBlock Grid.Column="4" Text="{x:Bind HCrit, Mode=OneWay}" TextAlignment="Right" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
