<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SwtorLogParser.Overlay.WinUi.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SwtorLogParser.Overlay.WinUi.ViewModels"
    Title="SWTOR Log Parser">

    <!-- Phase 10: borderless, always-on-top, layered translucent overlay. The whole window is given a
         constant alpha via WS_EX_LAYERED (WindowInterop.SetOpacity), so this opaque-dark panel renders as
         a readable translucent stats panel with the game showing through (WinForms Opacity parity).
         RequestedTheme=Dark gives light-on-dark text legible over a game scene. -->
    <Grid x:Name="Root" RequestedTheme="Dark" Background="#CC101010" Padding="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Control bar: drag grip (OVL-05), font +/- (OVL-08), click-through toggle (OVL-06),
             opacity slider (OVL-07 opacity). The grip is the move handle on a borderless window. -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" Margin="0,0,0,6"
                    VerticalAlignment="Center">
            <Border x:Name="DragHandle"
                    Background="#33FFFFFF" CornerRadius="3" Padding="8,2"
                    PointerPressed="DragHandle_PointerPressed"
                    ToolTipService.ToolTip="Drag to move">
                <TextBlock Text="⠿⠿" FontSize="14" />
            </Border>
            <Button Content="➕" Click="IncreaseFont_Click" ToolTipService.ToolTip="Increase font size" />
            <Button Content="➖" Click="DecreaseFont_Click" ToolTipService.ToolTip="Decrease font size" />
            <ToggleButton x:Name="ClickThroughToggle" Content="Click-through"
                          Click="ClickThroughToggle_Click"
                          ToolTipService.ToolTip="Pass the mouse through to the game (toggle with Ctrl+Alt+O)" />
            <TextBlock Text="Opacity" VerticalAlignment="Center" />
            <Slider x:Name="OpacitySlider" Width="90" Minimum="25" Maximum="100"
                    ValueChanged="OpacitySlider_ValueChanged" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Header row: 5 parity columns Player / DPS / Crit% / HPS / Crit% -->
        <Grid Grid.Row="1" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Player"  FontWeight="SemiBold" FontSize="{x:Bind FontSize, Mode=OneWay}" />
            <TextBlock Grid.Column="1" Text="DPS"     FontWeight="SemiBold" FontSize="{x:Bind FontSize, Mode=OneWay}" TextAlignment="Right" />
            <TextBlock Grid.Column="2" Text="Crit %"  FontWeight="SemiBold" FontSize="{x:Bind FontSize, Mode=OneWay}" TextAlignment="Right" />
            <TextBlock Grid.Column="3" Text="HPS"     FontWeight="SemiBold" FontSize="{x:Bind FontSize, Mode=OneWay}" TextAlignment="Right" />
            <TextBlock Grid.Column="4" Text="Crit %"  FontWeight="SemiBold" FontSize="{x:Bind FontSize, Mode=OneWay}" TextAlignment="Right" />
        </Grid>

        <!-- FontSize is an inherited dependency property: setting it on the ListView flows to the
             row TextBlocks (which do not override it), so the +/- buttons resize rows + header
             together (WinForms parity). -->
        <ListView Grid.Row="2"
                  ItemsSource="{x:Bind ViewModel.Rows}"
                  FontSize="{x:Bind FontSize, Mode=OneWay}"
                  SelectionMode="None"
                  IsItemClickEnabled="False"
                  Background="Transparent">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="4,2" />
                    <Setter Property="MinHeight" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:EntryViewModel">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Bind Name,  Mode=OneWay}" />
                        <TextBlock Grid.Column="1" Text="{x:Bind DPS,   Mode=OneWay}" TextAlignment="Right" />
                        <TextBlock Grid.Column="2" Text="{x:Bind DCrit, Mode=OneWay}" TextAlignment="Right" />
                        <TextBlock Grid.Column="3" Text="{x:Bind HPS,   Mode=OneWay}" TextAlignment="Right" />
                        <TextBlock Grid.Column="4" Text="{x:Bind HCrit, Mode=OneWay}" TextAlignment="Right" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
